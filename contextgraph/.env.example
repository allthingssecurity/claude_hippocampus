# Required: OpenAI API key for Graphiti entity/fact extraction
# Named GRAPHITI_OPENAI_KEY to avoid conflict with shell OPENAI_API_KEY
GRAPHITI_OPENAI_KEY=sk-...

# Neo4j password for the isolated trace database
NEO4J_PASSWORD=tracegraph2026

# Graphiti group ID (namespace for traces)
GRAPHITI_GROUP_ID=claude-traces

# Purge: days to keep raw episodes (entities/facts persist forever)
PURGE_RETENTION_DAYS=30
